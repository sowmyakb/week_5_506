# Course 506 Week 5 Skeleton — environment configuration
#
# Copy this file to .env (which is gitignored) and fill in your values.
#   cp .env.example .env
#   nano .env
#
# This file is OPTIONAL — the skeleton runs fine without it using the
# defaults baked into docker-compose.yml. Override only if you want to.

# Secret key signs Flask session cookies. Override this in production
# with a long random string.
# SECRET_KEY=dev-secret-not-for-production

# Database URL. Default points at the db service in Compose.
# DATABASE_URL=postgresql://app:app@db:5432/app
